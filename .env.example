# Agent Conduit — environment secrets template.
# Copy to `.env` and fill in. NEVER commit `.env`. Secrets live here, NOT in conduit.config.yaml.

# Database (Postgres default driver)
PGHOST=localhost
PGPORT=5432
PGDATABASE=conduit
PGUSER=conduit
PGPASSWORD=change-me-in-production

# Crypto — generate each with: `openssl rand -base64 32`
# AES-256-GCM master key for credential encryption at rest.
CONDUIT_MASTER_KEY=
# Ed25519 server signing material (key source — see crypto.signingKey in config).
CONDUIT_SIGNING_KEY=

# Server
CONDUIT_BASE_URL=https://localhost:8443
CONDUIT_PORT=8443
LOG_LEVEL=info

# TLS / ACME (only when tls.source = acme)
ACME_EMAIL=
