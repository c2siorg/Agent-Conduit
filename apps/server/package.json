{
  "name": "@conduit/server",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Conduit gateway — the four pillars (Identity, Connection Registry, Token Router, Observability) over Express.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "bootstrap:host": "node dist/scripts/bootstrapHost.js",
    "demo": "node dist/scripts/demoE2e.js",
    "example:agent": "node dist/scripts/exampleAgent.js"
  },
  "dependencies": {
    "@conduit/adapters": "*",
    "@conduit/connectors": "*",
    "@conduit/core": "*",
    "@conduit/crypto": "*",
    "@conduit/storage": "*",
    "acme-client": "^5.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.11.6"
  }
}
